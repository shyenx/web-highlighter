{
  "manifest_version": 3,
  "name": "Web Highlighter 网页高亮标注",
  "version": "0.6.4",
  "description": "框选网页文字一键高亮，按域名+路径持久化保存，支持撤销、改色、拖动工具栏。",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "显示/隐藏 高亮工具栏",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/10-i18n.js",
        "src/20-core.js",
        "src/30-storage.js",
        "src/40-range.js",
        "src/50-theme.js",
        "src/60-mark.js",
        "src/70-ui.js",
        "src/80-spa.js",
        "src/90-content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "toggle-toolbar": {
      "suggested_key": { "default": "Alt+H", "mac": "Alt+H" },
      "description": "显示/隐藏 高亮工具栏"
    },
    "undo-highlight": {
      "suggested_key": { "default": "Ctrl+Shift+Z", "mac": "Command+Shift+Z" },
      "description": "撤销最近的高亮操作"
    }
  }
}
